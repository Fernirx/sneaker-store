# Copy this file to .env and fill in your values.
# [dev default: x] = dev profile has a fallback, override only if needed
# [dev hardcoded: x] = value is fixed in application-dev.yaml, override to change it
# [required prod]    = must be set explicitly in production

# ──────────────────────────────────────────
# DOCKER (port mapping host:container)
# ──────────────────────────────────────────

# Host port exposed for the Spring Boot app
SERVER_HOST_PORT=8080

# Host port exposed for MySQL — use a different value if 3306 is already taken on host
DB_HOST_PORT=3306

# Host port exposed for Redis
REDIS_HOST_PORT=6379

# ──────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────

# [dev default: localhost] [prod: hardcoded "mysql" in docker-compose.prod.yml environment block — this value is ignored in Docker Compose]
DB_HOST=localhost

# [dev default: 3306] [CI/CD hardcoded: 3306]
# Docker Compose: app connects to MySQL via internal network, MySQL always listens on 3306.
# DB_HOST_PORT controls the host-side mapping only. Do NOT change this to match DB_HOST_PORT.
DB_PORT=3306

# [dev hardcoded: sneaker_store_db] [required prod]
DB_NAME=sneaker_store_db

# [dev default: root] [required prod]
DB_USERNAME=root

# [dev default:] [required prod]
DB_PASSWORD=

# Root password for the MySQL container (separate from DB_PASSWORD)
DB_ROOT_PASSWORD=

# ──────────────────────────────────────────
# REDIS
# ──────────────────────────────────────────

# [dev default: localhost] [prod: hardcoded "redis" in docker-compose.prod.yml environment block — this value is ignored in Docker Compose]
REDIS_HOST=localhost

# [dev default: 6379] [CI/CD hardcoded: 6379]
# Docker Compose: same as DB_PORT — Redis always listens on 6379 internally.
# REDIS_HOST_PORT controls the host-side mapping only. Do NOT change this to match REDIS_HOST_PORT.
REDIS_PORT=6379

# [dev default: (empty)] [required prod]
REDIS_PASSWORD=

# ──────────────────────────────────────────
# MAIL (Gmail SMTP)
# ──────────────────────────────────────────

# [dev default: smtp.gmail.com] [required prod]
MAIL_HOST=smtp.gmail.com

# [dev default: 587] [required prod]
MAIL_PORT=587

# [dev default: dev-email@gmail.com] [required prod]
MAIL_USERNAME=your-email@gmail.com

# [dev default: dev-app-password] [required prod] — use an App Password, not your Gmail password
MAIL_PASSWORD=your-app-password

# ──────────────────────────────────────────
# GOOGLE OAUTH2
# ──────────────────────────────────────────

# [dev default: changeme] [required prod] — obtain from Google Cloud Console
GOOGLE_CLIENT_ID=changeme

# [dev default: changeme] [required prod] — obtain from Google Cloud Console
GOOGLE_CLIENT_SECRET=changeme

# ──────────────────────────────────────────
# FACEBOOK OAUTH2
# ──────────────────────────────────────────

# [dev default: changeme] [required prod] — obtain from Meta for Developers (App ID)
FACEBOOK_APP_ID=changeme

# [dev default: changeme] [required prod] — obtain from Meta for Developers (App Secret)
FACEBOOK_APP_SECRET=changeme

# ──────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────

# [dev default: 8080] [prod default: 8080]
SERVER_PORT=8080

# [base default: /api]
SERVER_CONTEXT_PATH=/api

# ──────────────────────────────────────────
# CORS
# ──────────────────────────────────────────

# [dev default: http://localhost:3000,http://localhost:5173] [required prod]
# Comma-separated list of allowed origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ──────────────────────────────────────────
# JWT
# ──────────────────────────────────────────

# [dev default: dev-jwt-secret-key-for-local-development-only] [required prod]
# Must be a strong random string in production (e.g. 256-bit base64).
JWT_SECRET=your-secret-key

# [default: PT10M] — override only if needed (e.g. PT30S for quick dev testing)
JWT_ACCESS_EXPIRATION=PT10M

# [default: P7D]
JWT_REFRESH_EXPIRATION=P7D

# [default: PT15M]
JWT_RESET_PASSWORD_EXPIRATION=PT15M

# ──────────────────────────────────────────
# OTP
# ──────────────────────────────────────────

# [default: 5] — OTP expiry in minutes
OTP_TTL=5

# [default: 5] — max failed verification attempts before blocking
OTP_MAX_ATTEMPTS=5

# [default: 60] — cooldown in seconds before resending OTP
OTP_RESEND_COOLDOWN=60
